<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snygga Mattespelet</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="game-container">
        <h1>Mattemästaren</h1>
        
        <div class="score-board">
            <span>Poäng: <strong id="score">0</strong></span>
        </div>

        <div class="card">
            <div id="question" class="question">Redo?</div>
            <input type="number" id="answer-input" placeholder="Ditt svar..." autocomplete="off">
            <button id="submit-btn">Svara</button>
        </div>

        <div id="feedback" class="feedback"></div>
    </div>

    <script src="script.js"></script>
</body>
</html>
